generator client {
  provider = "prisma-client"
  output   = "../src/infra/database/prisma/generated/prisma/client"
}

datasource db {
  provider = "postgresql"
}

enum StatusEnum {
  ACTIVE
  INACTIVE
}

enum LangDirEnum {
  ltr
  rtl
}

enum IndustryEnum {
  CONSTRUCTION
  MANUFACTURING
  MINING
  PROPERTY
}

enum UserTypeEnum {
  DOMAIN
  USER
  ADMIN
  SUPERADMIN
}

enum ProductTypeEnum {
  RAW_MATERIAL
  FINISHED_PRODUCT
}

enum OnboardingStatusEnum {
  PENDING
  INPROGRESS
  COMPLETED
}

model Admin {
  id String @id @default(uuid()) @db.Uuid

  name      String
  email     String
  phoneCode String?
  phone     String?

  mediaId String? @db.Uuid
  media   Media?  @relation(fields: [mediaId], references: [id])

  password String

  isEmailVerified Boolean @default(false)
  isPhoneVerified Boolean @default(false)

  onboardingStatus OnboardingStatusEnum @default(PENDING)
  onboardingStep   String?

  status String @default("active")

  isDeleted Boolean @default(false)

  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  adminLanguages  AdminLanguages[]
  adminCurrencies AdminCurrencies[]
  domains         Domain[]

  @@unique([email, isDeleted])
  @@unique([phone, isDeleted])
}

model AdminLanguages {
  id         String   @id @default(uuid()) @db.Uuid
  adminId    String   @db.Uuid
  admin      Admin    @relation(fields: [adminId], references: [id], onDelete: Cascade)
  languageId String   @db.Uuid
  language   Language @relation(fields: [languageId], references: [id], onDelete: Restrict)
  isEnabled  Boolean  @default(false)
  isDefault  Boolean  @default(false)
  status     String   @default("active")
  isDeleted  Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model AdminCurrencies {
  id         String   @id @default(uuid()) @db.Uuid
  adminId    String   @db.Uuid
  admin      Admin    @relation(fields: [adminId], references: [id], onDelete: Cascade)
  currencyId String   @db.Uuid
  currency   Currency @relation(fields: [currencyId], references: [id])
  isEnabled  Boolean  @default(false)
  isDefault  Boolean  @default(false)
  status     String   @default("active")
  isDeleted  Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Domain {
  id               String       @id @default(uuid()) @db.Uuid
  name             Json
  searchText       String       @default("")
  email            String
  organizationType Json?
  phoneCode        String?
  phone            String?
  mediaId          String?      @db.Uuid
  industry         IndustryEnum
  password         String
  isEmailVerified  Boolean      @default(false)
  status           String       @default("active")
  isDeleted        Boolean      @default(false)
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  users                       User[]
  tokens                      Token[]
  otps                        Otp[]
  roles                       Role[]
  roleModulePermissions       RoleModulePermission[]
  inventories                 Inventory[]
  appErrors                   AppError[]
  vehicles                    Vehicle[]
  vehicleJourneySchedules     VehicleJourneySchedule[]
  dispatchVehicles            DispatchVehicle[]
  uoms                        Uom[]
  products                    Product[]
  productUoms                 ProductUom[]
  productGrades               ProductGrades[]
  productGradeStdRates        ProductGradeStdRates[]
  apiKeys                     ApiKey[]
  locations                   Location[]
  media                       Media[]
  projects                    Project[]
  projectCategories           ProjectCategory[]
  projectStages               ProjectStage[]
  projectTasks                ProjectTask[]
  projectTaskDelays           ProjectTaskDelay[]
  machineries                 Machinery[]
  rawMaterialPurchaseRequests RawMaterialPurchaseRequest[]
  projectUserRoles            ProjectUserRole[]
  admin                       Admin?                       @relation(fields: [adminId], references: [id])
  adminId                     String?                      @db.Uuid

  @@unique([email, isDeleted])
  @@unique([phone, isDeleted])
}

model User {
  id        String       @id @default(uuid()) @db.Uuid
  name      String
  email     String
  password  String
  phoneCode String?
  phone     String?
  industry  IndustryEnum
  roleId    String?      @db.Uuid

  role    Role?   @relation(fields: [roleId], references: [id])
  mediaId String? @db.Uuid

  isEmailVerified Boolean @default(false)
  domainId        String  @db.Uuid

  domain    Domain   @relation(fields: [domainId], references: [id])
  status    String   @default("active")
  isDeleted Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  rawMaterialPurchaseRequestsRequested RawMaterialPurchaseRequest[] @relation("RequestedByUser")
  projectUserRoles                     ProjectUserRole[]

  @@unique([email, isDeleted])
  @@unique([phone, isDeleted])
  @@index([createdAt, isDeleted, domainId])
  @@index([createdAt, isDeleted, status])
  @@index([createdAt, isDeleted, domainId, roleId])
}

model Token {
  id                  String   @id @default(uuid()) @db.Uuid
  token               String
  email               String
  tokenPurpose        String
  tokenExpirationTime DateTime
  domainId            String?  @db.Uuid

  domain    Domain?  @relation(fields: [domainId], references: [id])
  status    String   @default("active")
  isDeleted Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([createdAt, isDeleted])
}

model Otp {
  id        String   @id @default(uuid()) @db.Uuid
  email     String
  otp       String
  expiresAt DateTime
  attempts  Int      @default(0)
  domainId  String?  @db.Uuid

  domain    Domain?  @relation(fields: [domainId], references: [id])
  isUsed    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email, isUsed])
  @@index([createdAt])
}

model RefreshToken {
  id        String       @id @default(uuid()) @db.Uuid
  token     String       @unique
  expiry    DateTime
  userType  UserTypeEnum
  userId    String       @db.Uuid
  status    String       @default("active")
  isDeleted Boolean      @default(false)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  @@index([token, isDeleted])
  @@index([userId, userType, isDeleted])
  @@index([createdAt])
}

model Currency {
  id              String            @id @default(uuid()) @db.Uuid
  name            Json
  code            String
  searchText      String            @default("")
  symbol          String
  flag            String
  status          String            @default("active")
  isDeleted       Boolean           @default(false)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  adminCurrencies AdminCurrencies[]

  @@map("currency")
}

model Role {
  id         String  @id @default(uuid()) @db.Uuid
  name       String
  code       String?
  searchText String  @default("")
  level      Int     @default(0)
  domainId   String  @db.Uuid

  domain    Domain   @relation(fields: [domainId], references: [id])
  status    String   @default("active")
  isDeleted Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users                 User[]
  roleModulePermissions RoleModulePermission[]
  projectUserRoles      ProjectUserRole[]

  @@unique([code, domainId, isDeleted])
  @@index([createdAt, isDeleted])
  @@index([createdAt, isDeleted, status])
  @@index([createdAt, isDeleted, domainId])
}

model Module {
  id                            String   @id @default(uuid()) @db.Uuid
  name                          Json
  code                          String
  searchText                    String   @default("")
  parentDependenciesCount       Int      @default(0)
  activeParentDependenciesCount Int      @default(0)
  status                        String   @default("active")
  isDeleted                     Boolean  @default(false)
  createdAt                     DateTime @default(now())
  updatedAt                     DateTime @updatedAt

  roleModulePermissions RoleModulePermission[]
  modulePermissions     ModulePermission[]
  parentDependencies    ModuleDependency[]     @relation("ParentModule")
  childDependencies     ModuleDependency[]     @relation("DependentModule")

  @@unique([code, isDeleted])
  @@index([isDeleted])
  @@index([createdAt, isDeleted])
  @@index([createdAt, isDeleted, status])
}

model Permission {
  id                          String                       @id @default(uuid()) @db.Uuid
  name                        Json
  code                        String
  searchText                  String                       @default("")
  status                      String                       @default("active")
  isDeleted                   Boolean                      @default(false)
  createdAt                   DateTime                     @default(now())
  updatedAt                   DateTime                     @updatedAt
  modulePermissions           ModulePermission[]
  moduleDependencyPermissions ModuleDependencyPermission[]

  @@unique([code, isDeleted])
  @@index([createdAt, isDeleted])
  @@index([createdAt, isDeleted, status])
  @@map("permission")
}

model RoleModulePermission {
  id     String @id @default(uuid()) @db.Uuid
  roleId String @db.Uuid

  role     Role   @relation(fields: [roleId], references: [id])
  moduleId String @db.Uuid

  module      Module   @relation(fields: [moduleId], references: [id])
  permissions String[]
  domainId    String   @db.Uuid

  domain    Domain   @relation(fields: [domainId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([roleId, moduleId, domainId])
  @@index([createdAt, domainId])
  @@index([createdAt, roleId, domainId])
  @@index([createdAt, roleId, moduleId, domainId])
}

model ModulePermission {
  id           String @id @default(uuid()) @db.Uuid
  moduleId     String @db.Uuid
  permissionId String @db.Uuid

  module     Module     @relation(fields: [moduleId], references: [id])
  permission Permission @relation(fields: [permissionId], references: [id])
  isDeleted  Boolean    @default(false)
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  @@unique([moduleId, permissionId])
  @@index([createdAt, moduleId])
  @@index([createdAt])
}

model ModuleDependency {
  id       String @id @default(uuid()) @db.Uuid
  moduleId String @db.Uuid

  module            Module @relation("ParentModule", fields: [moduleId], references: [id])
  dependentModuleId String @db.Uuid

  isDeleted                   Boolean                      @default(false)
  dependentModule             Module                       @relation("DependentModule", fields: [dependentModuleId], references: [id])
  createdAt                   DateTime                     @default(now())
  updatedAt                   DateTime                     @updatedAt
  moduleDependencyPermissions ModuleDependencyPermission[]

  @@unique([moduleId, dependentModuleId])
  @@index([createdAt])
  @@index([createdAt, moduleId])
}

model ModuleDependencyPermission {
  id                 String @id @default(uuid()) @db.Uuid
  moduleDependencyId String @db.Uuid

  moduleDependency ModuleDependency @relation(fields: [moduleDependencyId], references: [id])
  permissionId     String           @db.Uuid

  isDeleted Boolean @default(false)

  permission Permission @relation(fields: [permissionId], references: [id])
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  @@unique([moduleDependencyId, permissionId])
}

model Inventory {
  id             String        @id @default(uuid()) @db.Uuid
  productId      String        @db.Uuid
  product        Product       @relation(fields: [productId], references: [id])
  productGradeId String        @db.Uuid
  productGrade   ProductGrades @relation(fields: [productGradeId], references: [id])
  quantity       Float         @default(0)
  uomId          String        @db.Uuid
  uom            Uom           @relation("InventoryUom", fields: [uomId], references: [id])
  reorderLevel   Float         @default(0)
  domainId       String        @db.Uuid
  domain         Domain        @relation(fields: [domainId], references: [id])
  status         String        @default("active")
  isDeleted      Boolean       @default(false)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@unique([productId, productGradeId, domainId, isDeleted])
  @@index([domainId, isDeleted])
}

model AppError {
  id           String @id @default(uuid()) @db.Uuid
  deviceName   String
  version      String
  error        String @db.Text
  functionName String
  domainId     String @db.Uuid

  domain    Domain   @relation(fields: [domainId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([createdAt])
}

model Log {
  id           String   @id @default(uuid()) @db.Uuid
  endpoint     String
  statusCode   Int
  requestData  String?  @db.Text
  responseData String?  @db.Text
  method       String
  responseTime Int
  deviceId     String?
  deviceIP     String?
  appVersion   String?
  createdAt    DateTime @default(now())

  @@index([createdAt])
  @@index([createdAt, statusCode])
}

model Language {
  id             String           @id @default(uuid()) @db.Uuid
  name           String
  code           String
  flag           String
  dir            LangDirEnum      @default(ltr)
  status         String           @default("active")
  isDeleted      Boolean          @default(false)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  adminLanguages AdminLanguages[]

  @@unique([code, isDeleted])
  @@index([createdAt, isDeleted])
  @@index([createdAt, isDeleted, status])
}

model SuperAdmin {
  id        String   @id @default(uuid()) @db.Uuid
  name      Json
  email     String
  password  String
  status    String   @default("active")
  isDeleted Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([email, isDeleted])
  @@index([createdAt, isDeleted])
  @@map("superAdmin")
}

model Uom {
  id          String  @id @default(uuid()) @db.Uuid
  displayName Json
  code        String
  searchText  String  @default("")
  baseUomId   String? @db.Uuid

  conversionRate Float
  domainId       String @db.Uuid

  domain    Domain   @relation(fields: [domainId], references: [id])
  status    String   @default("active")
  isDeleted Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  productUoms                 ProductUom[]                 @relation("ProductUom")
  vehicleLoadCapacity         Vehicle[]                    @relation("VehicleLoadCapacityUom")
  journeyScheduleLoadedQty    VehicleJourneySchedule[]     @relation("JourneyScheduleLoadedQtyUom")
  dispatchLoadedQty           DispatchVehicle[]            @relation("DispatchLoadedQtyUom")
  inventories                 Inventory[]                  @relation("InventoryUom")
  rawMaterialPurchaseRequests RawMaterialPurchaseRequest[]

  @@unique([code, domainId, isDeleted])
  @@index([createdAt, isDeleted])
}

model Vehicle {
  id                String  @id @default(uuid()) @db.Uuid
  numberPlate       String
  vehicleType       String  @default("TRUCK")
  loadCapacity      Float   @default(0)
  loadCapacityUomId String? @db.Uuid

  loadCapacityUom    Uom?   @relation("VehicleLoadCapacityUom", fields: [loadCapacityUomId], references: [id])
  alertLoadThreshold Float  @default(0)
  domainId           String @db.Uuid

  domain    Domain   @relation(fields: [domainId], references: [id])
  status    String   @default("active")
  isDeleted Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  journeySchedules VehicleJourneySchedule[]
  dispatches       DispatchVehicle[]

  @@unique([numberPlate, isDeleted])
  @@index([createdAt, isDeleted, domainId])
}

model VehicleJourneySchedule {
  id      String @id @default(uuid()) @db.Uuid
  truckId String @db.Uuid

  truck               Vehicle   @relation(fields: [truckId], references: [id])
  code                String
  description         String?
  date                DateTime?
  driverName          String?
  startLocation       String?
  endLocation         String?
  distance            Float     @default(0)
  average             Float     @default(0)
  expectedFuelValue   Float     @default(0)
  fuelAlertThreshold  Float     @default(0)
  loadedQuantity      Float     @default(0)
  loadedQuantityUomId String?   @db.Uuid

  loadedQuantityUom Uom?      @relation("JourneyScheduleLoadedQtyUom", fields: [loadedQuantityUomId], references: [id])
  loadedAt          DateTime?
  loadingStatus     String    @default("PENDING")
  domainId          String    @db.Uuid

  domain    Domain   @relation(fields: [domainId], references: [id])
  status    String   @default("active")
  isDeleted Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  dispatches DispatchVehicle[]

  @@unique([code, domainId, isDeleted, truckId])
  @@index([createdAt, isDeleted, domainId])
}

model DispatchVehicle {
  id        String @id @default(uuid()) @db.Uuid
  vehicleId String @db.Uuid

  vehicle           Vehicle @relation(fields: [vehicleId], references: [id])
  code              String
  journeyScheduleId String? @db.Uuid

  journeySchedule     VehicleJourneySchedule? @relation(fields: [journeyScheduleId], references: [id])
  description         String?
  date                DateTime?
  driverName          String?
  startLocation       String?
  endLocation         String?
  distance            Float                   @default(0)
  average             Float                   @default(0)
  expectedFuelValue   Float                   @default(0)
  actualFuelValue     Float                   @default(0)
  fuelAlertThreshold  Float                   @default(0)
  loadedQuantity      Float                   @default(0)
  loadedQuantityUomId String?                 @db.Uuid

  loadedQuantityUom      Uom?      @relation("DispatchLoadedQtyUom", fields: [loadedQuantityUomId], references: [id])
  loadedAt               DateTime?
  loadingStatus          String    @default("PENDING")
  journeyStatus          String    @default("SCHEDULED")
  journeyStatusUpdatedAt DateTime?
  domainId               String    @db.Uuid

  domain    Domain   @relation(fields: [domainId], references: [id])
  status    String   @default("active")
  isDeleted Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([code, domainId, isDeleted, vehicleId])
  @@index([createdAt, isDeleted, domainId])
  @@index([journeyStatus, isDeleted, domainId])
}

model Product {
  id          String          @id @default(uuid()) @db.Uuid
  displayName Json
  code        String
  productType ProductTypeEnum
  searchText  String          @default("")
  domainId    String          @db.Uuid

  domain               Domain                 @relation(fields: [domainId], references: [id])
  productGrades        ProductGrades[]
  productGradeStdRates ProductGradeStdRates[]
  inventories          Inventory[]
  status               String
  isDeleted            Boolean                @default(false)
  createdAt            DateTime               @default(now())
  updatedAt            DateTime               @updatedAt

  productUoms                 ProductUom[]
  rawMaterialPurchaseRequests RawMaterialPurchaseRequest[]

  @@unique([code, domainId, isDeleted])
  @@index([isDeleted])
  @@index([createdAt, isDeleted, domainId])
  @@index([createdAt, isDeleted, status])
}

model ProductUom {
  id        String @id @default(uuid()) @db.Uuid
  productId String @db.Uuid

  product Product @relation(fields: [productId], references: [id])
  uomId   String  @db.Uuid

  uom      Uom    @relation("ProductUom", fields: [uomId], references: [id])
  domainId String @db.Uuid

  domain    Domain   @relation(fields: [domainId], references: [id])
  status    String
  isDeleted Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([productId, uomId])
}

model ProductGrades {
  id                          String                       @id @default(uuid()) @db.Uuid
  productId                   String                       @db.Uuid
  gradeDisplayName            Json
  gradeCode                   String
  searchText                  String                       @default("")
  domainId                    String                       @db.Uuid
  domain                      Domain                       @relation(fields: [domainId], references: [id])
  product                     Product                      @relation(fields: [productId], references: [id])
  productGradeStdRates        ProductGradeStdRates[]
  inventories                 Inventory[]
  rawMaterialPurchaseRequests RawMaterialPurchaseRequest[]
  status                      String
  isDeleted                   Boolean
  createdAt                   DateTime                     @default(now())
  updatedAt                   DateTime                     @updatedAt

  @@unique([gradeCode, productId, domainId, isDeleted])
  @@index([isDeleted])
  @@index([createdAt, isDeleted, domainId])
  @@index([createdAt, isDeleted, status])
}

model ProductGradeStdRates {
  id             String        @id @default(uuid()) @db.Uuid
  productGradeId String        @db.Uuid
  productId      String        @db.Uuid
  stdRateType    Json
  searchText     String        @default("")
  stdRateValue   Float
  alertThresold  Float
  domainId       String        @db.Uuid
  domain         Domain        @relation(fields: [domainId], references: [id])
  product        Product       @relation(fields: [productId], references: [id])
  productGrade   ProductGrades @relation(fields: [productGradeId], references: [id])
  status         String
  isDeleted      Boolean
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@index([isDeleted])
  @@index([createdAt, isDeleted, domainId])
  @@index([createdAt, isDeleted, status])
}

enum PurchaseRequestType {
  IMPORT
  LOCAL
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

model RawMaterialPurchaseRequest {
  id                            String              @id @default(uuid()) @db.Uuid
  code                          String
  type                          PurchaseRequestType
  date                          DateTime            @default(now())
  productId                     String              @db.Uuid
  product                       Product             @relation(fields: [productId], references: [id])
  productGradeId                String              @db.Uuid
  productGrade                  ProductGrades       @relation(fields: [productGradeId], references: [id])
  quantity                      Float
  uomId                         String              @db.Uuid
  uom                           Uom                 @relation(fields: [uomId], references: [id])
  vendor                        String?
  brand                         String?
  requisitionRequestDocumentUrl String?
  requestedBy                   String              @db.Uuid
  requestedUser                 User                @relation("RequestedByUser", fields: [requestedBy], references: [id])
  requiredBy                    DateTime
  reason                        String
  approvalStatus                ApprovalStatus      @default(PENDING)
  approvedAt                    DateTime?
  projectId                     String              @db.Uuid
  project                       Project             @relation(fields: [projectId], references: [id])
  domainId                      String              @db.Uuid
  domain                        Domain              @relation(fields: [domainId], references: [id])
  status                        StatusEnum          @default(ACTIVE)
  isDeleted                     Boolean             @default(false)
  createdAt                     DateTime            @default(now())
  updatedAt                     DateTime            @updatedAt

  @@unique([code, domainId, isDeleted])
  @@index([createdAt, isDeleted, domainId])
  @@index([createdAt, isDeleted, domainId, status])
  @@index([productId])
  @@index([productGradeId])
  @@index([uomId])
  @@index([requestedBy])
  @@index([projectId])
  @@index([domainId])
}

model ApiKey {
  id          String     @id @default(uuid()) @db.Uuid
  name        String
  description String?
  secret      String
  domainId    String     @db.Uuid
  domain      Domain     @relation(fields: [domainId], references: [id], onDelete: Cascade)
  status      StatusEnum @default(ACTIVE)
  isDeleted   Boolean    @default(false)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([domainId])
}

model Location {
  id               String     @id @default(uuid()) @db.Uuid
  name             Json       @db.JsonB
  code             String
  type             String
  parentLocationId String?    @db.Uuid
  parent           Location?  @relation("LocationHierarchy", fields: [parentLocationId], references: [id])
  children         Location[] @relation("LocationHierarchy")
  domainId         String     @db.Uuid
  domain           Domain     @relation(fields: [domainId], references: [id], onDelete: Cascade)
  status           StatusEnum @default(ACTIVE)
  isDeleted        Boolean    @default(false)
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  projects Project[]

  @@unique([code, isDeleted, domainId])
  @@index([domainId])
  @@index([parentLocationId])
}

model Media {
  id        String     @id @default(uuid()) @db.Uuid
  name      String
  type      String
  url       String     @unique
  domainId  String     @db.Uuid
  domain    Domain     @relation(fields: [domainId], references: [id], onDelete: Cascade)
  status    StatusEnum @default(ACTIVE)
  isDeleted Boolean    @default(false)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  admins    Admin[]

  @@index([domainId])
  @@map("media")
}

model Project {
  id                String          @id @default(uuid()) @db.Uuid
  name              Json            @db.JsonB
  code              String
  projectCategoryId String          @db.Uuid
  projectCategory   ProjectCategory @relation(fields: [projectCategoryId], references: [id], onDelete: Restrict)
  description       Json?           @db.JsonB
  budget            Decimal         @db.Decimal(15, 2)
  spent             Decimal         @default(0) @db.Decimal(15, 2)
  locationId        String          @db.Uuid
  location          Location        @relation(fields: [locationId], references: [id], onDelete: Restrict)
  domainId          String          @db.Uuid
  domain            Domain          @relation(fields: [domainId], references: [id], onDelete: Cascade)
  status            StatusEnum      @default(ACTIVE)
  isDeleted         Boolean         @default(false)
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  projectStages               ProjectStage[]
  projectTasks                ProjectTask[]
  projectTaskDelays           ProjectTaskDelay[]
  machineries                 Machinery[]
  rawMaterialPurchaseRequests RawMaterialPurchaseRequest[]
  projectUserRoles            ProjectUserRole[]

  @@unique([code, isDeleted, domainId])
  @@index([projectCategoryId])
  @@index([locationId])
  @@index([domainId])
}

model ProjectCategory {
  id          String     @id @default(uuid()) @db.Uuid
  name        Json       @db.JsonB
  code        String
  description Json?      @db.JsonB
  domainId    String     @db.Uuid
  domain      Domain     @relation(fields: [domainId], references: [id], onDelete: Cascade)
  status      StatusEnum @default(ACTIVE)
  isDeleted   Boolean    @default(false)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  projects Project[]

  @@unique([code, isDeleted, domainId])
  @@index([domainId])
}

model ProjectStage {
  id          String     @id @default(uuid()) @db.Uuid
  name        Json       @db.JsonB
  code        String
  description Json?      @db.JsonB
  progress    Float?
  projectId   String     @db.Uuid
  project     Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  domainId    String     @db.Uuid
  domain      Domain     @relation(fields: [domainId], references: [id], onDelete: Cascade)
  status      StatusEnum @default(ACTIVE)
  isDeleted   Boolean    @default(false)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  projectTasks      ProjectTask[]
  projectTaskDelays ProjectTaskDelay[]

  @@unique([code, isDeleted, domainId, projectId])
  @@index([projectId])
  @@index([domainId])
}

model ProjectTask {
  id                   String       @id @default(uuid()) @db.Uuid
  name                 Json         @db.JsonB
  code                 String
  assignee             Json?        @db.JsonB
  plannedStartDate     DateTime?
  plannedEndDate       DateTime?
  actualStartDate      DateTime?
  actualEndDate        DateTime?
  taskStatus           String       @default("PENDING")
  taskProgress         Float        @default(0)
  totalDelayInDays     Float        @default(0)
  requiredApproval     Boolean      @default(false)
  lastApprovedDeadline DateTime?
  projectBatchCode     String?
  stageId              String       @db.Uuid
  stage                ProjectStage @relation(fields: [stageId], references: [id], onDelete: Cascade)
  projectId            String       @db.Uuid
  project              Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  domainId             String       @db.Uuid
  domain               Domain       @relation(fields: [domainId], references: [id], onDelete: Cascade)
  status               StatusEnum   @default(ACTIVE)
  isDeleted            Boolean      @default(false)
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt

  projectTaskDelays ProjectTaskDelay[]

  @@unique([code, isDeleted, domainId, projectId, stageId])
  @@index([createdAt, isDeleted, domainId])
  @@index([createdAt, isDeleted, domainId, status])
  @@index([createdAt, isDeleted, domainId, projectId])
  @@index([createdAt, isDeleted, domainId, projectId, stageId])
}

model ProjectTaskDelay {
  id                   String       @id @default(uuid()) @db.Uuid
  taskId               String       @db.Uuid
  task                 ProjectTask  @relation(fields: [taskId], references: [id], onDelete: Cascade)
  requestedDelayInDays Float        @default(0)
  delayReason          String
  requestApproved      Boolean      @default(false)
  requestApprovalTime  DateTime?
  stageId              String       @db.Uuid
  stage                ProjectStage @relation(fields: [stageId], references: [id], onDelete: Cascade)
  projectId            String       @db.Uuid
  project              Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  domainId             String       @db.Uuid
  domain               Domain       @relation(fields: [domainId], references: [id], onDelete: Cascade)
  status               StatusEnum   @default(ACTIVE)
  isDeleted            Boolean      @default(false)
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt

  @@index([createdAt, isDeleted, domainId])
  @@index([createdAt, isDeleted, domainId, status])
  @@index([createdAt, isDeleted, domainId, projectId])
  @@index([createdAt, isDeleted, domainId, projectId, stageId])
  @@index([createdAt, isDeleted, domainId, projectId, taskId])
}

model Machinery {
  id                   String     @id @default(uuid()) @db.Uuid
  code                 String
  type                 String
  expectedLitrePerHour Float      @default(0)
  projectId            String     @db.Uuid
  project              Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  domainId             String     @db.Uuid
  domain               Domain     @relation(fields: [domainId], references: [id], onDelete: Cascade)
  status               StatusEnum @default(ACTIVE)
  isDeleted            Boolean    @default(false)
  createdAt            DateTime   @default(now())
  updatedAt            DateTime   @updatedAt

  @@index([createdAt, isDeleted, domainId])
  @@index([createdAt, isDeleted, domainId, status])
  @@index([createdAt, isDeleted, domainId, projectId])
}

model ProjectUserRole {
  id        String     @id @default(uuid()) @db.Uuid
  projectId String     @db.Uuid
  project   Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  userId    String     @db.Uuid
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  roleId    String     @db.Uuid
  role      Role       @relation(fields: [roleId], references: [id], onDelete: Restrict)
  domainId  String     @db.Uuid
  domain    Domain     @relation(fields: [domainId], references: [id], onDelete: Cascade)
  status    StatusEnum @default(ACTIVE)
  isDeleted Boolean    @default(false)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@unique([userId, roleId, projectId, domainId, isDeleted])
  @@index([createdAt, domainId])
  @@index([createdAt, domainId, userId])
  @@index([createdAt, domainId, roleId])
  @@index([createdAt, domainId, projectId])
}
