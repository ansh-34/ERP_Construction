  domain            Domain     @relation(fields: [domainId], references: [id], onDelete: Cascade)
  adminId           String     @db.Uuid
  admin             Admin      @relation(fields: [adminId], references: [id], onDelete: Restrict)
  status            StatusEnum @default(ACTIVE)
  isDeleted         Boolean    @default(false)
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  @@index([createdAt, isDeleted, domainId], map: "pudl_created_deleted_domain_idx")
  @@index([createdAt, isDeleted, domainId, projectId], map: "pudl_created_deleted_domain_project_idx")
  @@index([createdAt, isDeleted, domainId, userId], map: "pudl_created_deleted_domain_user_idx")
  @@index([createdAt, isDeleted, domainId, projectId, userId], map: "pudl_created_deleted_domain_project_user_idx")
