generator client {
  provider = "prisma-client"
  output   = "../src/infra/database/prisma/generated/prisma/client"
}

datasource db {
  provider = "postgresql"
}

enum StatusEnum {
  ACTIVE
  INACTIVE
}

enum LangDirEnum {
  ltr
  rtl
}

enum IndustryEnum {
  CONSTRUCTION
  MANUFACTURING
  MINING
  PROPERTY
}

enum UserTypeEnum {
  DOMAIN
  USER
  ADMIN
  SUPERADMIN
}

enum ProductTypeEnum {
  RAW_MATERIAL
  FINISHED_PRODUCT
}

enum OnboardingStatusEnum {
  PENDING
  INPROGRESS
  COMPLETED
}

model Admin {
  id String @id @default(uuid()) @db.Uuid

  name      String
  email     String
  phoneCode String?
  phone     String?

  mediaId String? @db.Uuid
  media   Media?  @relation(fields: [mediaId], references: [id])

  password String

  offeredLanguagesCount  Int @default(0)
  enabledLanguagesCount  Int @default(0)
  offeredCurrenciesCount Int @default(0)
  enabledCurrenciesCount Int @default(0)

  isEmailVerified Boolean @default(false)
  isPhoneVerified Boolean @default(false)

  onboardingStatus OnboardingStatusEnum @default(PENDING)
  onboardingStep   String?

  status StatusEnum @default(ACTIVE)

  isDeleted Boolean @default(false)

  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt
  adminLanguages         AdminLanguages[]
  adminCurrencies        AdminCurrencies[]
  domains                Domain[]
  projects               Project[]
  projectStages          ProjectStage[]
  projectTasks           ProjectTask[]
  projectTaskImages      ProjectTaskImage[]
  projectTaskDelays      ProjectTaskDelay[]
  projectUserAssignments ProjectUserAssignment[]
  projectUserDailyLogs   ProjectUserDailyLog[]
  apiKeys                ApiKey[]
  locations              Location[]
  machineries            Machinery[]
  machineReadings        MachineReading[]
  maintenanceSchedules   MaintenanceSchedule[]
  maintenanceLogs        MaintenanceLog[]
  movementLogs           MovementLog[]
  mediaFiles             Media[]                 @relation("AdminMediaFiles")
  users                  User[]
  roles                  Role[]

  @@unique([email, isDeleted])
  @@unique([phone, isDeleted])
}

model AdminLanguages {
  id         String     @id @default(uuid()) @db.Uuid
  adminId    String     @db.Uuid
  admin      Admin      @relation(fields: [adminId], references: [id], onDelete: Cascade)
  languageId String     @db.Uuid
  language   Language   @relation(fields: [languageId], references: [id], onDelete: Restrict)
  isEnabled  Boolean    @default(false)
  isDefault  Boolean    @default(false)
  status     StatusEnum @default(ACTIVE)
  isDeleted  Boolean    @default(false)
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
}

model AdminCurrencies {
  id         String     @id @default(uuid()) @db.Uuid
  adminId    String     @db.Uuid
  admin      Admin      @relation(fields: [adminId], references: [id], onDelete: Cascade)
  currencyId String     @db.Uuid
  currency   Currency   @relation(fields: [currencyId], references: [id])
  isEnabled  Boolean    @default(false)
  isDefault  Boolean    @default(false)
  status     StatusEnum @default(ACTIVE)
  isDeleted  Boolean    @default(false)
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
}

model Domain {
  id                         String       @id @default(uuid()) @db.Uuid
  name                       Json
  nameSearchText             String       @default("")
  email                      String
  organizationType           Json?
  organizationTypeSearchText String       @default("")
  phoneCode                  String?
  phone                      String?
  mediaId                    String?      @db.Uuid
  industry                   IndustryEnum
  password                   String
  isEmailVerified            Boolean      @default(false)

  onboardingStatus OnboardingStatusEnum @default(PENDING)
  onboardingStep   String?

  status    StatusEnum @default(ACTIVE)
  isDeleted Boolean    @default(false)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  users                       User[]
  tokens                      Token[]
  otps                        Otp[]
  roles                       Role[]
  roleModulePermissions       RoleModulePermission[]
  inventories                 Inventory[]
  appErrors                   AppError[]
  vehicles                    Vehicle[]
  vehicleJourneySchedules     VehicleJourneySchedule[]
  grns                        Grn[]
  grnProducts                 GrnProduct[]
  dispatchVehicles            DispatchVehicle[]
  uoms                        Uom[]
  products                    Product[]
  productUoms                 ProductUom[]
  productGrades               ProductGrades[]
  productGradeStdRates        ProductGradeStdRates[]
  apiKeys                     ApiKey[]
  locations                   Location[]
  media                       Media[]
  projects                    Project[]
  projectCategories           ProjectCategory[]
  projectStages               ProjectStage[]
  projectTasks                ProjectTask[]
  projectTaskImages           ProjectTaskImage[]
  projectTaskDelays           ProjectTaskDelay[]
  projectUserAssignments      ProjectUserAssignment[]
  projectUserDailyLogs        ProjectUserDailyLog[]
  machineries                 Machinery[]
  machineReadings             MachineReading[]
  maintenanceSchedules        MaintenanceSchedule[]
  maintenanceLogs             MaintenanceLog[]
  movementLogs                MovementLog[]
  rawMaterialPurchaseRequests RawMaterialPurchaseRequest[]
  purchaseOrders              PurchaseOrder[]
  vendors                     Vendor[]
  vendorProductPricings       VendorProductPricing[]
  purchaseOrderProducts       PurchaseOrderProduct[]
  invoices                    Invoice[]
  invoiceItems                InvoiceItem[]
  admin                       Admin                        @relation(fields: [adminId], references: [id])
  adminId                     String                       @db.Uuid

  @@unique([email, isDeleted])
  @@unique([phone, isDeleted])
}

model User {
  id           String       @id @default(uuid()) @db.Uuid
  name         String
  email        String
  password     String
  phoneCode    String?
  phone        String?
  industry     IndustryEnum
  skills       String[]     @default([])
  minDayCharge Decimal?     @db.Decimal(15, 2)
  roleId       String?      @db.Uuid

  role    Role?   @relation(fields: [roleId], references: [id])
  mediaId String? @db.Uuid

  isEmailVerified Boolean @default(false)

  onboardingStatus OnboardingStatusEnum @default(PENDING)
  onboardingStep   String?

  domainId String @db.Uuid

  domain    Domain     @relation(fields: [domainId], references: [id])
  adminId   String?    @db.Uuid
  admin     Admin?     @relation(fields: [adminId], references: [id])
  status    StatusEnum @default(ACTIVE)
  isDeleted Boolean    @default(false)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  rawMaterialPurchaseRequestsRequested RawMaterialPurchaseRequest[] @relation("RequestedByUser")
  projectUserAssignments               ProjectUserAssignment[]
  projectUserDailyLogs                 ProjectUserDailyLog[]

  @@unique([email, isDeleted])
  @@unique([phone, isDeleted])
  @@index([createdAt, isDeleted, domainId])
  @@index([createdAt, isDeleted, status])
  @@index([createdAt, isDeleted, domainId, roleId])
}

model Token {
  id                  String   @id @default(uuid()) @db.Uuid
  token               String
  email               String
  tokenPurpose        String
  tokenExpirationTime DateTime
  domainId            String?  @db.Uuid

  domain    Domain?    @relation(fields: [domainId], references: [id])
  status    StatusEnum @default(ACTIVE)
  isDeleted Boolean    @default(false)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@index([createdAt, isDeleted])
}

model Otp {
  id        String   @id @default(uuid()) @db.Uuid
  email     String
  otp       String
  expiresAt DateTime
  attempts  Int      @default(0)
  domainId  String?  @db.Uuid

  domain    Domain?  @relation(fields: [domainId], references: [id])
  isUsed    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email, isUsed])
  @@index([createdAt])
}

model RefreshToken {
  id        String       @id @default(uuid()) @db.Uuid
  token     String       @unique
  expiry    DateTime
  userType  UserTypeEnum
  userId    String       @db.Uuid
  status    StatusEnum   @default(ACTIVE)
  isDeleted Boolean      @default(false)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  @@index([token, isDeleted])
  @@index([userId, userType, isDeleted])
  @@index([createdAt])
}

model Currency {
  id              String            @id @default(uuid()) @db.Uuid
  name            Json
  code            String
  searchText      String            @default("")
  symbol          String
  flag            String
  status          StatusEnum        @default(ACTIVE)
  isDeleted       Boolean           @default(false)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  adminCurrencies AdminCurrencies[]

  @@map("currency")
}

model Role {
  id         String  @id @default(uuid()) @db.Uuid
  name       Json    @db.JsonB
  code       String?
  searchText String  @default("")
  level      Int     @default(0)
  domainId   String  @db.Uuid
  adminId    String? @db.Uuid

  admin     Admin?     @relation(fields: [adminId], references: [id])
  domain    Domain     @relation(fields: [domainId], references: [id])
  status    StatusEnum @default(ACTIVE)
  isDeleted Boolean    @default(false)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  users                 User[]
  roleModulePermissions RoleModulePermission[]

  @@unique([code, domainId, isDeleted])
  @@index([createdAt, isDeleted])
  @@index([createdAt, isDeleted, status])
  @@index([createdAt, isDeleted, domainId])
}

model Module {
  id                            String     @id @default(uuid()) @db.Uuid
  name                          Json
  code                          String
  searchText                    String     @default("")
  parentDependenciesCount       Int        @default(0)
  activeParentDependenciesCount Int        @default(0)
  status                        StatusEnum @default(ACTIVE)
  isDeleted                     Boolean    @default(false)
  createdAt                     DateTime   @default(now())
  updatedAt                     DateTime   @updatedAt

  roleModulePermissions RoleModulePermission[]
  modulePermissions     ModulePermission[]
  parentDependencies    ModuleDependency[]     @relation("ParentModule")
  childDependencies     ModuleDependency[]     @relation("DependentModule")

  @@unique([code, isDeleted])
  @@index([isDeleted])
  @@index([createdAt, isDeleted])
  @@index([createdAt, isDeleted, status])
}

model Permission {
  id                          String                       @id @default(uuid()) @db.Uuid
  name                        Json
  code                        String
  searchText                  String                       @default("")
  status                      StatusEnum                   @default(ACTIVE)
  isDeleted                   Boolean                      @default(false)
  createdAt                   DateTime                     @default(now())
  updatedAt                   DateTime                     @updatedAt
  modulePermissions           ModulePermission[]
  moduleDependencyPermissions ModuleDependencyPermission[]

  @@unique([code, isDeleted])
  @@index([createdAt, isDeleted])
  @@index([createdAt, isDeleted, status])
  @@map("permission")
}

model RoleModulePermission {
  id     String @id @default(uuid()) @db.Uuid
  roleId String @db.Uuid

  role     Role   @relation(fields: [roleId], references: [id])
  moduleId String @db.Uuid

  module      Module   @relation(fields: [moduleId], references: [id])
  permissions String[]
  domainId    String   @db.Uuid

  domain    Domain   @relation(fields: [domainId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([roleId, moduleId, domainId])
  @@index([createdAt, domainId])
  @@index([createdAt, roleId, domainId])
  @@index([createdAt, roleId, moduleId, domainId])
}

model ModulePermission {
  id           String @id @default(uuid()) @db.Uuid
  moduleId     String @db.Uuid
  permissionId String @db.Uuid

  module     Module     @relation(fields: [moduleId], references: [id])
  permission Permission @relation(fields: [permissionId], references: [id])
  isDeleted  Boolean    @default(false)
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  @@unique([moduleId, permissionId])
  @@index([createdAt, moduleId])
  @@index([createdAt])
}

model ModuleDependency {
  id       String @id @default(uuid()) @db.Uuid
  moduleId String @db.Uuid

  module            Module @relation("ParentModule", fields: [moduleId], references: [id])
  dependentModuleId String @db.Uuid

  isDeleted                   Boolean                      @default(false)
  dependentModule             Module                       @relation("DependentModule", fields: [dependentModuleId], references: [id])
  createdAt                   DateTime                     @default(now())
  updatedAt                   DateTime                     @updatedAt
  moduleDependencyPermissions ModuleDependencyPermission[]

  @@unique([moduleId, dependentModuleId])
  @@index([createdAt])
  @@index([createdAt, moduleId])
}

model ModuleDependencyPermission {
  id                 String @id @default(uuid()) @db.Uuid
  moduleDependencyId String @db.Uuid

  moduleDependency ModuleDependency @relation(fields: [moduleDependencyId], references: [id])
  permissionId     String           @db.Uuid

  isDeleted Boolean @default(false)

  permission Permission @relation(fields: [permissionId], references: [id])
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  @@unique([moduleDependencyId, permissionId])
}

model Inventory {
  id             String        @id @default(uuid()) @db.Uuid
  productId      String        @db.Uuid
  product        Product       @relation(fields: [productId], references: [id])
  productGradeId String        @db.Uuid
  productGrade   ProductGrades @relation(fields: [productGradeId], references: [id])
  quantity       Float         @default(0)
  uomId          String        @db.Uuid
  uom            Uom           @relation("InventoryUom", fields: [uomId], references: [id])
  reorderLevel   Float         @default(0)
  domainId       String        @db.Uuid
  domain         Domain        @relation(fields: [domainId], references: [id])
  status         StatusEnum    @default(ACTIVE)
  isDeleted      Boolean       @default(false)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@unique([productId, productGradeId, domainId, isDeleted])
  @@index([domainId, isDeleted])
}

model AppError {
  id           String @id @default(uuid()) @db.Uuid
  deviceName   String
  version      String
  error        String @db.Text
  functionName String
  domainId     String @db.Uuid

  domain    Domain   @relation(fields: [domainId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([createdAt])
}

model Log {
  id           String   @id @default(uuid()) @db.Uuid
  endpoint     String
  statusCode   Int
  requestData  String?  @db.Text
  responseData String?  @db.Text
  method       String
  responseTime Int
  deviceId     String?
  deviceIP     String?
  appVersion   String?
  createdAt    DateTime @default(now())

  @@index([createdAt])
  @@index([createdAt, statusCode])
}

model Language {
  id             String           @id @default(uuid()) @db.Uuid
  name           String
  code           String
  flag           String
  dir            LangDirEnum      @default(ltr)
  status         StatusEnum       @default(ACTIVE)
  isDeleted      Boolean          @default(false)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  adminLanguages AdminLanguages[]

  @@unique([code, isDeleted])
  @@index([createdAt, isDeleted])
  @@index([createdAt, isDeleted, status])
}

model SuperAdmin {
  id        String     @id @default(uuid()) @db.Uuid
  name      Json
  email     String
  password  String
  status    StatusEnum @default(ACTIVE)
  isDeleted Boolean    @default(false)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@unique([email, isDeleted])
  @@index([createdAt, isDeleted])
  @@map("superAdmin")
}

model Uom {
  id          String  @id @default(uuid()) @db.Uuid
  displayName Json
  code        String
  searchText  String  @default("")
  baseUomId   String? @db.Uuid

  conversionRate Float
  domainId       String @db.Uuid

  domain    Domain     @relation(fields: [domainId], references: [id])
  status    StatusEnum @default(ACTIVE)
  isDeleted Boolean    @default(false)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  productUoms                 ProductUom[]                 @relation("ProductUom")
  vehicleLoadCapacity         Vehicle[]                    @relation("VehicleLoadCapacityUom")
  journeyScheduleLoadedQty    VehicleJourneySchedule[]     @relation("JourneyScheduleLoadedQtyUom")
  dispatchLoadedQty           DispatchVehicle[]            @relation("DispatchLoadedQtyUom")
  inventories                 Inventory[]                  @relation("InventoryUom")
  rawMaterialPurchaseRequests RawMaterialPurchaseRequest[]
  grnProducts                 GrnProduct[]
  purchaseOrderProducts       PurchaseOrderProduct[]
  vendorProductPricings       VendorProductPricing[]
  invoiceItems                InvoiceItem[]

  @@unique([code, domainId, isDeleted])
  @@index([createdAt, isDeleted])
}

model Vehicle {
  id                String  @id @default(uuid()) @db.Uuid
  numberPlate       String
  vehicleType       String  @default("TRUCK")
  loadCapacity      Float   @default(0)
  loadCapacityUomId String? @db.Uuid

  loadCapacityUom    Uom?   @relation("VehicleLoadCapacityUom", fields: [loadCapacityUomId], references: [id])
  alertLoadThreshold Float  @default(0)
  domainId           String @db.Uuid

  domain    Domain     @relation(fields: [domainId], references: [id])
  status    StatusEnum @default(ACTIVE)
  isDeleted Boolean    @default(false)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  journeySchedules     VehicleJourneySchedule[]
  dispatches           DispatchVehicle[]
  maintenanceSchedules MaintenanceSchedule[]
  maintenanceLogs      MaintenanceLog[]
  movementLogs         MovementLog[]

  @@unique([numberPlate, isDeleted])
  @@index([createdAt, isDeleted, domainId])
}

model VehicleJourneySchedule {
  id      String @id @default(uuid()) @db.Uuid
  truckId String @db.Uuid

  truck               Vehicle   @relation(fields: [truckId], references: [id])
  code                String
  description         String?
  date                DateTime?
  driverName          String?
  startLocation       String?
  endLocation         String?
  distance            Float     @default(0)
  average             Float     @default(0)
  expectedFuelValue   Float     @default(0)
  fuelAlertThreshold  Float     @default(0)
  loadedQuantity      Float     @default(0)
  loadedQuantityUomId String?   @db.Uuid

  loadedQuantityUom Uom?      @relation("JourneyScheduleLoadedQtyUom", fields: [loadedQuantityUomId], references: [id])
  loadedAt          DateTime?
  loadingStatus     String    @default("PENDING")
  domainId          String    @db.Uuid

  domain    Domain     @relation(fields: [domainId], references: [id])
  status    StatusEnum @default(ACTIVE)
  isDeleted Boolean    @default(false)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  dispatches DispatchVehicle[]

  @@unique([code, domainId, isDeleted, truckId])
  @@index([createdAt, isDeleted, domainId])
}

model DispatchVehicle {
  id        String @id @default(uuid()) @db.Uuid
  vehicleId String @db.Uuid

  vehicle           Vehicle @relation(fields: [vehicleId], references: [id])
  code              String
  journeyScheduleId String? @db.Uuid

  journeySchedule     VehicleJourneySchedule? @relation(fields: [journeyScheduleId], references: [id])
  description         String?
  date                DateTime?
  driverName          String?
  startLocation       String?
  endLocation         String?
  distance            Float                   @default(0)
  average             Float                   @default(0)
  expectedFuelValue   Float                   @default(0)
  actualFuelValue     Float                   @default(0)
  fuelAlertThreshold  Float                   @default(0)
  loadedQuantity      Float                   @default(0)
  loadedQuantityUomId String?                 @db.Uuid

  loadedQuantityUom      Uom?      @relation("DispatchLoadedQtyUom", fields: [loadedQuantityUomId], references: [id])
  loadedAt               DateTime?
  loadingStatus          String    @default("PENDING")
  journeyStatus          String    @default("SCHEDULED")
  journeyStatusUpdatedAt DateTime?
  domainId               String    @db.Uuid

  domain    Domain     @relation(fields: [domainId], references: [id])
  status    StatusEnum @default(ACTIVE)
  isDeleted Boolean    @default(false)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@unique([code, domainId, isDeleted, vehicleId])
  @@index([createdAt, isDeleted, domainId])
  @@index([journeyStatus, isDeleted, domainId])
}

model Product {
  id          String          @id @default(uuid()) @db.Uuid
  displayName Json
  code        String
  productType ProductTypeEnum
  searchText  String          @default("")
  domainId    String          @db.Uuid

  domain               Domain                 @relation(fields: [domainId], references: [id])
  productGrades        ProductGrades[]
  productGradeStdRates ProductGradeStdRates[]
  inventories          Inventory[]
  status               StatusEnum             @default(ACTIVE)
  isDeleted            Boolean                @default(false)
  createdAt            DateTime               @default(now())
  updatedAt            DateTime               @updatedAt

  productUoms                 ProductUom[]
  rawMaterialPurchaseRequests RawMaterialPurchaseRequest[]
  vendorProductPricings       VendorProductPricing[]
  invoiceItems                InvoiceItem[]

  @@unique([code, domainId, isDeleted])
  @@index([isDeleted])
  @@index([createdAt, isDeleted, domainId])
  @@index([createdAt, isDeleted, status])
}

model ProductUom {
  id        String @id @default(uuid()) @db.Uuid
  productId String @db.Uuid

  product Product @relation(fields: [productId], references: [id])
  uomId   String  @db.Uuid

  uom      Uom    @relation("ProductUom", fields: [uomId], references: [id])
  domainId String @db.Uuid

  domain    Domain     @relation(fields: [domainId], references: [id])
  status    StatusEnum @default(ACTIVE)
  isDeleted Boolean    @default(false)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@unique([productId, uomId])
}

model ProductGrades {
  id                          String                       @id @default(uuid()) @db.Uuid
  productId                   String                       @db.Uuid
  gradeDisplayName            Json
  gradeCode                   String
  searchText                  String                       @default("")
  domainId                    String                       @db.Uuid
  domain                      Domain                       @relation(fields: [domainId], references: [id])
  product                     Product                      @relation(fields: [productId], references: [id])
  productGradeStdRates        ProductGradeStdRates[]
  inventories                 Inventory[]
  rawMaterialPurchaseRequests RawMaterialPurchaseRequest[]
  vendorProductPricings       VendorProductPricing[]
  invoiceItems                InvoiceItem[]
  status                      StatusEnum                   @default(ACTIVE)
  isDeleted                   Boolean
  createdAt                   DateTime                     @default(now())
  updatedAt                   DateTime                     @updatedAt

  @@unique([gradeCode, productId, domainId, isDeleted])
  @@index([isDeleted])
  @@index([createdAt, isDeleted, domainId])
  @@index([createdAt, isDeleted, status])
}

model ProductGradeStdRates {
  id             String        @id @default(uuid()) @db.Uuid
  productGradeId String        @db.Uuid
  productId      String        @db.Uuid
  stdRateType    Json
  searchText     String        @default("")
  stdRateValue   Float
  alertThresold  Float
  domainId       String        @db.Uuid
  domain         Domain        @relation(fields: [domainId], references: [id])
  product        Product       @relation(fields: [productId], references: [id])
  productGrade   ProductGrades @relation(fields: [productGradeId], references: [id])
  status         StatusEnum    @default(ACTIVE)
  isDeleted      Boolean
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@index([isDeleted])
  @@index([createdAt, isDeleted, domainId])
  @@index([createdAt, isDeleted, status])
}

enum PurchaseRequestType {
  IMPORT
  LOCAL
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum POStatus {
  PENDING_VENDOR
  INVOICED
}

enum PaymentStatus {
  UNPAID
  PARTIALLY_PAID
  PAID
}

enum MaintenanceAssetType {
  VEHICLE
  MACHINERY
}

enum MaintenanceScheduleStatus {
  SCHEDULED
  OVERDUE
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum MovementType {
  WAREHOUSE
  WAREHOUSE_TO_SITE
  SITE_TO_WAREHOUSE
  PROJECT_SITE
  SITE_TO_SITE
  OTHER
}

model RawMaterialPurchaseRequest {
  id              String              @id @default(uuid()) @db.Uuid
  code            String
  type            PurchaseRequestType
  date            DateTime            @default(now())
  productId       String              @db.Uuid
  product         Product             @relation(fields: [productId], references: [id])
  productGradeId  String              @db.Uuid
  productGrade    ProductGrades       @relation(fields: [productGradeId], references: [id])
  quantity        Float
  uomId           String              @db.Uuid
  uom             Uom                 @relation(fields: [uomId], references: [id])
  brand           String?
  documentId      String?             @db.Uuid
  document        Media?              @relation(fields: [documentId], references: [id])
  requestedBy     String              @db.Uuid
  requestedUser   User                @relation("RequestedByUser", fields: [requestedBy], references: [id])
  requiredBy      DateTime
  reason          String?
  approvalStatus  ApprovalStatus      @default(PENDING)
  approvedAt      DateTime?
  projectId       String              @db.Uuid
  project         Project             @relation(fields: [projectId], references: [id])
  domainId        String              @db.Uuid
  domain          Domain              @relation(fields: [domainId], references: [id])
  status          StatusEnum          @default(ACTIVE)
  isDeleted       Boolean             @default(false)
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
