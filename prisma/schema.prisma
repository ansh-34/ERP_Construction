  id                String     @id @default(uuid()) @db.Uuid
  startDate         DateTime
  endDate           DateTime
  projectId         String     @db.Uuid
  project           Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  userId            String     @db.Uuid
  user              User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  dailyWorkingHours Float
  dayCharge         Decimal    @db.Decimal(15, 2)
  notes             String?
  domainId          String     @db.Uuid
  domain            Domain     @relation(fields: [domainId], references: [id], onDelete: Cascade)
  adminId           String     @db.Uuid
  admin             Admin      @relation(fields: [adminId], references: [id], onDelete: Restrict)
  status            StatusEnum @default(ACTIVE)
  isDeleted         Boolean    @default(false)
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  @@index([createdAt, isDeleted, domainId], map: "pua_created_deleted_domain_idx")
  @@index([createdAt, isDeleted, domainId, projectId], map: "pua_created_deleted_domain_project_idx")
  @@index([createdAt, isDeleted, domainId, userId], map: "pua_created_deleted_domain_user_idx")
  @@index([createdAt, isDeleted, domainId, projectId, userId], map: "pua_created_deleted_domain_project_user_idx")
  @@index([adminId])
}

model ProjectUserDailyLog {
