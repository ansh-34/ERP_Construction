  id                String              @id @default(uuid()) @db.Uuid
  customerId        String              @db.Uuid
  customer          Customer            @relation(fields: [customerId], references: [id], onDelete: Restrict)
  paidDate          DateTime            @db.Date
  amount            Float
  outstandingAmount Float               @default(0)
  roundOffAmount    Float               @default(0)
  paymentType       CustomerPaymentType @default(CASH)
  cashLedgerId      String?             @db.Uuid
  remarks           String?
  searchText        String              @default("")
  createdBy         String?             @db.Uuid
  domainId          String              @db.Uuid
  domain            Domain              @relation(fields: [domainId], references: [id], onDelete: Cascade)
  adminId           String              @db.Uuid
  admin             Admin               @relation(fields: [adminId], references: [id], onDelete: Restrict)
  status            StatusEnum          @default(ACTIVE)
  isDeleted         Boolean             @default(false)
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  @@index([domainId, isDeleted])
  @@index([customerId])
  @@index([paidDate])
  @@index([adminId])
  @@index([createdBy])
}

model FiscalYear {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  startDate DateTime @db.Date
  endDate   DateTime @db.Date
  isClosed  Boolean  @default(false)
  closedAt  DateTime?
  closedBy  String?  @db.Uuid
  closedByUserId String? @db.Uuid
  adminId   String   @db.Uuid
  domainId  String   @db.Uuid
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  domain Domain @relation(fields: [domainId], references: [id], onDelete: Cascade)
  admin  Admin  @relation("FiscalYearCreatedBy", fields: [adminId], references: [id], onDelete: Restrict)
  closer Admin? @relation("FiscalYearClosedBy", fields: [closedBy], references: [id], onDelete: Restrict)
  closingUser User? @relation("FiscalYearClosedByUser", fields: [closedByUserId], references: [id], onDelete: Restrict)
  accountingPeriods AccountingPeriod[]

  @@unique([name, domainId])
  @@index([domainId, isClosed])
  @@index([adminId])
  @@index([closedBy])
  @@index([closedByUserId])
}

model AccountingPeriod {
  id           String   @id @default(uuid()) @db.Uuid
  fiscalYearId String   @db.Uuid
  name         String
  periodNo     Int
  startDate    DateTime @db.Date
  endDate      DateTime @db.Date
  isClosed     Boolean  @default(false)
  closedAt     DateTime?
  closedBy     String?  @db.Uuid
  closedByUserId String? @db.Uuid
  domainId     String   @db.Uuid
  adminId      String   @db.Uuid
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  fiscalYear FiscalYear @relation(fields: [fiscalYearId], references: [id], onDelete: Cascade)
  domain     Domain     @relation(fields: [domainId], references: [id], onDelete: Cascade)
  admin      Admin      @relation("AccountingPeriodCreatedBy", fields: [adminId], references: [id], onDelete: Restrict)
  closer     Admin?     @relation("AccountingPeriodClosedBy", fields: [closedBy], references: [id], onDelete: Restrict)
  closingUser User?     @relation("AccountingPeriodClosedByUser", fields: [closedByUserId], references: [id], onDelete: Restrict)

  @@unique([fiscalYearId, periodNo])
  @@unique([fiscalYearId, name])
  @@index([domainId, isClosed])
  @@index([adminId])
  @@index([closedBy])
  @@index([closedByUserId])
}

model CustomerRate {
  id             String        @id @default(uuid()) @db.Uuid
  customerId     String        @db.Uuid
  customer       Customer      @relation(fields: [customerId], references: [id], onDelete: Restrict)
  productId      String        @db.Uuid
  product        Product       @relation(fields: [productId], references: [id], onDelete: Restrict)
  productGradeId String        @db.Uuid
  productGrade   ProductGrades @relation(fields: [productGradeId], references: [id], onDelete: Restrict)
  rate           Float
  currencyId     String        @db.Uuid
  currency       Currency      @relation(fields: [currencyId], references: [id], onDelete: Restrict)
  uomId          String        @db.Uuid
  uom            Uom           @relation(fields: [uomId], references: [id], onDelete: Restrict)
  effectiveFrom  DateTime      @db.Date
  effectiveTo    DateTime?     @db.Date
  domainId       String        @db.Uuid
  domain         Domain        @relation(fields: [domainId], references: [id], onDelete: Cascade)
  adminId        String        @db.Uuid
  admin          Admin         @relation(fields: [adminId], references: [id], onDelete: Restrict)
  status         StatusEnum    @default(ACTIVE)
  isDeleted      Boolean       @default(false)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@index([domainId, isDeleted])
  @@index([customerId])
  @@index([productId])
  @@index([productGradeId])
  @@index([adminId])
}
